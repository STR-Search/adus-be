# n8n automation webhook (fired on deal_status -> present_to_clients)
#
# Two URLs, same uuid, different path:
#   /webhook/<uuid>       production — ALWAYS LIVE. Every event runs the real
#                         workflow and its downstream actions.
#   /webhook-test/<uuid>  test — only accepts a request while the workflow is in
#                         "Listen for test event" mode in the n8n editor;
#                         returns 404 otherwise.
#
# Left disabled here on purpose: the URL below is the live one, so enabling it
# locally will trigger real automation. Flip to true only when you mean it.
N8N_WEBHOOK_ENABLED=false
N8N_WEBHOOK_URL=https://[DOMAIN].com/webhook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxx
N8N_WEBHOOK_TIMEOUT_SECONDS=10
